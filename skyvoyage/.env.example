# MongoDB (gateway)
MONGODB_URI=mongodb://127.0.0.1:27017/skyvoyage

# JWT (gateway)
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Ports
PORT=3001
JAVA_SERVICE_URL=http://localhost:8085
PYTHON_SERVICE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Amadeus (Java + Python) — https://developers.amadeus.com/
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
# test (default) vs production shopping — set AMADEUS_PRODUCTION=true or AMADEUS_ENV=production
# AMADEUS_PRODUCTION=true

# Duffel (Java) — live NDC / multi-source offers, indie-friendly — https://duffel.com/
DUFFEL_ACCESS_TOKEN=
# DUFFEL_API_BASE=https://api.duffel.com

# AviationStack — https://aviationstack.com/
AVIATION_STACK_KEY=

# OpenAI (Python chatbot only)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Java engine data directory (logs + e-tickets)
SKYVOYAGE_DATA_DIR=./skyvoyage-data
JAVA_ENGINE_PORT=8085

# Flight search cache TTL (gateway, ms)
FLIGHT_CACHE_TTL_MS=900000
